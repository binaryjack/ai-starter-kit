{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": ["node", "jest"]
  }
}