{
  "name": "@ai-agencee/ai-starter-kit-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm sync-icons && pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "sync-icons": "node scripts/sync-icons.js",
    "dev:dag-editor": "pnpm sync-icons && pnpm --filter @ai-agencee/dag-editor run dev",
    "dev:showcase": "pnpm sync-icons && pnpm --filter @ai-agencee/showcase-web run dev",
    "dev:sites": "pnpm sync-icons && pnpm --filter @ai-agencee/dag-editor --filter @ai-agencee/showcase-web --parallel run dev",
    "demo": "pnpm build && node scripts/demo.js",
    "demo:dag": "node scripts/demo.js",
    "run:dag": "node packages/cli/dist/bin/ai-kit.js agent:dag",
    "run:plan": "node packages/cli/dist/bin/ai-kit.js plan",
    "demo:menu": "node scripts/run-scenarios.js",
    "demo:all": "node scripts/run-scenarios.js all",
    "demo:01": "node scripts/run-scenarios.js 1",
    "demo:02": "node scripts/run-scenarios.js 2",
    "demo:03": "node scripts/run-scenarios.js 3",
    "demo:04": "node scripts/run-scenarios.js 4",
    "demo:05": "node scripts/run-scenarios.js 5",
    "demo:06": "node scripts/run-scenarios.js 6",
    "demo:plan": "node scripts/plan-demo.js",
    "demo:plan:01": "node scripts/plan-demo.js 1",
    "demo:plan:02": "node scripts/plan-demo.js 2",
    "demo:plan:03": "node scripts/plan-demo.js 3",
    "demo:plan:04": "node scripts/plan-demo.js 4",
    "demo:plan:05": "node scripts/plan-demo.js 5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.35",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
