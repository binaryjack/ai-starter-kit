{
  "laneId": "permission-matrix",
  "retryBudget": 1,
  "checkpoints": [
    {
      "checkpointId": "step-0",
      "mode": "read-contract",
      "expect": {
        "contractAvailable": true
      },
      "onFail": "ESCALATE"
    },
    {
      "checkpointId": "step-1",
      "mode": "self",
      "expect": {
        "hasAllRoles": true,
        "hasEscalationPrevention": true
      },
      "onFail": "RETRY",
      "retryInstructions": "Permission matrix must cover all 4 roles (OWNER/ADMIN/MEMBER/VIEWER) and explicitly address permission escalation prevention (no tenant can self-escalate)"
    }
  ],
  "publishContract": {
    "key": "permission-matrix",
    "outputKeys": ["permission-matrix"]
  }
}
