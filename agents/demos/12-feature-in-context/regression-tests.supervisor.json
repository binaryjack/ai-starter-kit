{
  "laneId": "regression-tests",
  "retryBudget": 1,
  "checkpoints": [
    {
      "checkpointId": "step-0",
      "mode": "read-contract",
      "expect": { "contractAvailable": true },
      "onFail": "ESCALATE"
    },
    {
      "checkpointId": "step-1",
