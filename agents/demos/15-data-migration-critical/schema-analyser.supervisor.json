      "onFail": "RETRY",
      "retryInstructions": "Re-run ensuring PII field map and complete table inventory with row counts are documented"
    }
  ],
  "publishContract": {
    "key": "schema-analysis",
    "outputKeys": ["schema-analysis"]
  }
}
