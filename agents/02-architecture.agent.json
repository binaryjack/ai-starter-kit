      "failRecommendations": ["Add ESLint configuration to enforce code quality"]
    },
    {
      "type": "file-exists",
      "path": ".eslintrc.js",
      "pass": "✅ ESLint configured (.eslintrc.js)"
    },
    {
      "type": "file-exists",
      "path": "eslint.config.js",
      "pass": "✅ ESLint v9 flat config found"
    },
    {
      "type": "file-exists",
      "path": ".prettierrc",
      "pass": "✅ Prettier configured",
      "fail": "ℹ️  No Prettier config found",
      "failRecommendations": ["Add .prettierrc to enforce consistent code formatting"]
    }
  ]
