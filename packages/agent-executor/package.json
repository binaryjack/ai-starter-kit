{
  "name": "@ai-agencee/engine",
  "version": "1.1.0",
  "description": "Agent orchestration and execution engine for AI Agencee",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-agents.js",
    "prepublishOnly": "pnpm run build",
    "test": "jest",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ai-agencee/core": "workspace:^1.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
